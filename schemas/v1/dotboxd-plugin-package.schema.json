{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JKamsker/Safe-IR/schemas/v1/dotboxd-plugin-package.schema.json",
  "title": "DotBoxD Plugin Package Envelope",
  "description": "Versioned JSON Schema for the plugin package envelope accepted by PluginPackageJsonSerializer.Import(string json). Mirrors the importer's strict shape for the manifest, embedded module, live settings, hook subscriptions, and kernel entrypoints. The 'module' property follows the Safe IR module envelope schema (dotboxd-kernel-module.schema.json). Schema version is tracked by the directory segment (v1) and the schemaVersion constant; bump both when the JSON contract changes.",
  "x-dotboxd-schema-version": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest", "module"],
  "properties": {
    "manifest": { "$ref": "#/$defs/manifest" },
    "module": {
      "$ref": "https://github.com/JKamsker/Safe-IR/schemas/v1/dotboxd-kernel-module.schema.json"
    },
    "entrypoints": { "$ref": "#/$defs/entrypoints" }
  },
  "$defs": {
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pluginId", "contract", "mode", "effects", "liveSettings", "subscriptions"],
      "properties": {
        "pluginId": { "type": "string" },
        "contract": { "type": "string" },
        "mode": {
          "type": "string",
          "pattern": "^(?:[Aa][Uu][Tt][Oo]|[Ii][Nn][Tt][Ee][Rr][Pp][Rr][Ee][Tt][Ee][Dd]|[Cc][Oo][Mm][Pp][Ii][Ll][Ee][Dd])$",
          "description": "Parsed case-insensitively into the ExecutionMode enum."
        },
        "effects": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["Cpu", "Alloc", "Time", "Random", "FileRead", "FileWrite", "Network", "HostStateRead", "HostStateWrite", "Concurrency", "Audit"]
          }
        },
        "liveSettings": {
          "type": "array",
          "items": { "$ref": "#/$defs/liveSetting" }
        },
        "subscriptions": {
          "type": "array",
          "items": { "$ref": "#/$defs/subscription" }
        },
        "requiredCapabilities": {
          "type": "array",
          "description": "Analyzer-derived capabilities the verified IR requires. Optional for back-compat.",
          "items": { "type": "string" }
        },
        "rpcEntrypoint": {
          "type": "string",
          "description": "For a kernel RPC service: the request/response batch entrypoint function id. Absent for event kernels."
        }
      }
    },
    "liveSetting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "defaultValue"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["bool", "int", "long", "double", "string"] },
        "defaultValue": { "$ref": "#/$defs/liveSettingValue" },
        "min": { "$ref": "#/$defs/liveSettingValue" },
        "max": { "$ref": "#/$defs/liveSettingValue" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "bool" } }, "required": ["type"] },
          "then": {
            "properties": {
              "defaultValue": { "type": ["boolean", "null"] },
              "min": { "type": "null" },
              "max": { "type": "null" }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "int" } }, "required": ["type"] },
          "then": {
            "properties": {
              "defaultValue": { "type": ["integer", "null"], "minimum": -2147483648, "maximum": 2147483647 },
              "min": { "type": ["integer", "null"], "minimum": -2147483648, "maximum": 2147483647 },
              "max": { "type": ["integer", "null"], "minimum": -2147483648, "maximum": 2147483647 }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "long" } }, "required": ["type"] },
          "then": {
            "properties": {
              "defaultValue": { "type": ["integer", "null"], "minimum": -9223372036854775808, "maximum": 9223372036854775807 },
              "min": { "type": ["integer", "null"], "minimum": -9223372036854775808, "maximum": 9223372036854775807 },
              "max": { "type": ["integer", "null"], "minimum": -9223372036854775808, "maximum": 9223372036854775807 }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "double" } }, "required": ["type"] },
          "then": {
            "properties": {
              "defaultValue": { "type": ["number", "null"], "minimum": -1.7976931348623157e308, "maximum": 1.7976931348623157e308 },
              "min": { "type": ["number", "null"], "minimum": -1.7976931348623157e308, "maximum": 1.7976931348623157e308 },
              "max": { "type": ["number", "null"], "minimum": -1.7976931348623157e308, "maximum": 1.7976931348623157e308 }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "string" } }, "required": ["type"] },
          "then": {
            "properties": {
              "defaultValue": { "type": ["string", "null"] },
              "min": { "type": "null" },
              "max": { "type": "null" }
            }
          }
        }
      ]
    },
    "liveSettingValue": {
      "description": "A JSON scalar (or null) interpreted according to the live setting 'type'.",
      "type": ["boolean", "integer", "number", "string", "null"]
    },
    "subscription": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event", "kernel"],
      "properties": {
        "event": { "type": "string" },
        "kernel": { "type": "string" },
        "indexedPredicates": {
          "type": "array",
          "description": "Host-readable, index-eligible '.Where(...)' constraints (issue #47). Each is a necessary AND condition of the verified predicate, so a host may reject events on any of them. Optional; omitted when the predicate had no index-eligible leaves.",
          "items": { "$ref": "#/$defs/indexedPredicate" }
        },
        "indexCoversPredicate": {
          "type": "boolean",
          "description": "True only when the verified predicate is exactly the conjunction of indexedPredicates, so a host whose index check passes may skip the verified IR. Optional; defaults to false."
        },
        "localTerminal": {
          "type": "boolean",
          "description": "True for a lowered RunLocal chain: the verified IR filters and projects server-side and the host pushes only the projected value to the plugin's native delegate. Optional; defaults to false."
        },
        "projectedType": {
          "type": "string",
          "description": "The manifest type of the Select projection a local-terminal chain returns (bool/int/long/double/string). Optional; present only when localTerminal is true."
        },
        "priority": {
          "type": "integer",
          "minimum": -2147483648,
          "maximum": 2147483647,
          "description": "Dispatch priority for a lowered result-returning hook chain. Higher values run first. Optional; defaults to 0."
        },
        "resultType": {
          "type": "string",
          "description": "Fully qualified hook result type for a lowered Register/RegisterLocal result hook chain. Optional; omitted for notification hooks."
        },
        "resultLocalTerminal": {
          "type": "boolean",
          "description": "True for a remote RegisterLocal result hook whose result is produced by the plugin process through request/response callback. Optional; defaults to false."
        }
      }
    },
    "indexedPredicate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "operator", "value", "valueType"],
      "properties": {
        "path": { "type": "string", "description": "The event property the constraint compares." },
        "operator": {
          "type": "string",
          "enum": ["Equals", "NotEquals", "GreaterThan", "GreaterThanOrEqual", "LessThan", "LessThanOrEqual"],
          "description": "Comparison normalized so the event property is the left operand."
        },
        "value": {
          "description": "The compile-time constant compared against, as a JSON scalar interpreted per 'valueType'.",
          "type": ["boolean", "integer", "number", "string"]
        },
        "valueType": { "type": "string", "enum": ["bool", "int", "long", "double", "string"] }
      }
    },
    "entrypoints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "shouldHandle": { "type": "string" },
        "handle": { "type": "string" }
      }
    }
  }
}
