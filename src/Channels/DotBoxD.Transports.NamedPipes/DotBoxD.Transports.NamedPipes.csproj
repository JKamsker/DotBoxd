<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <PackageId>DotBoxD.Transports.NamedPipes</PackageId>
    <Description>Named pipe transport implementation for DotBoxD process-boundary IPC.</Description>
    <PackageTags>dotboxd;transport;named-pipes;ipc;rpc</PackageTags>
    <PackageReadmeFile>named-pipe-transport.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Services\DotBoxD.Services\DotBoxD.Services.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Expose the internal connect-published seam to the test assembly for a deterministic red→green
         dispose-vs-connect race test. No external surface. -->
    <InternalsVisibleTo Include="DotBoxD.Services.Tests" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\..\docs-site\src\content\docs\channels\named-pipe-transport.md"
          Pack="true"
          PackagePath="\" />
  </ItemGroup>

</Project>
