<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <!-- Primary package: ships the runtime core AND the bundled source generator
         as a single "DotBoxd" package, so consumers install one thing. -->
    <PackageId>DotBoxd.Services</PackageId>
    <Description>High-performance, transport-agnostic RPC framework for C#. Bundles the runtime core and the source generator (compile-time client proxies and server dispatchers).</Description>
  </PropertyGroup>

  <ItemGroup>
    <!-- Expose internal test seams (e.g. RpcPeer.HasStarted, catalog registration override) to the
         test assembly so race-condition fixes can be covered by deterministic red→green tests. No
         external surface — the test assembly is not shipped. -->
    <InternalsVisibleTo Include="DotBoxd.Services.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.IO.Pipelines" />
    <PackageReference Include="System.Collections.Immutable" />
    <PackageReference Include="System.Threading.Channels" />

    <!-- Build the generator before this project so its assembly exists at pack time.
         ReferenceOutputAssembly=false: it ships as an analyzer, not a runtime reference. -->
    <ProjectReference Include="..\..\CodeGeneration\DotBoxd.Services.SourceGenerator\DotBoxd.Services.SourceGenerator.csproj"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <!-- Pack the generator into analyzers/dotnet/cs of this package so any SDK-based
         consumer auto-loads it. Replaces the standalone DotBoxd.Services.SourceGenerator package. -->
    <None Include="..\..\CodeGeneration\DotBoxd.Services.SourceGenerator\bin\$(Configuration)\netstandard2.0\DotBoxd.Services.SourceGenerator.dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
  </ItemGroup>

</Project>
