<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>DotBoxD</PackageId>
    <IsPackable>true</IsPackable>
    <Description>DotBoxD meta-package: pulls in the full stack across all three usage modes — Services (source-generated RPC), Kernels (validated sandboxed logic hosted via DotBoxD.Hosting), and Pushdown (running kernels next to host services). Reference this single package to get the complete DotBoxD surface for a net10.0 host.</Description>
    <PackageTags>dotboxd;rpc;sandbox;kernels;pushdown;meta</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Services\DotBoxD.Services\DotBoxD.Services.csproj" />
    <ProjectReference Include="..\..\Kernels\DotBoxD.Kernels\DotBoxD.Kernels.csproj" />
    <ProjectReference Include="..\..\Hosting\DotBoxD.Abstractions\DotBoxD.Abstractions.csproj" />
    <ProjectReference Include="..\..\Hosting\DotBoxD.Hosting\DotBoxD.Hosting.csproj" />
    <ProjectReference Include="..\..\Hosting\DotBoxD.Plugins\DotBoxD.Plugins.csproj" />
    <ProjectReference Include="..\..\CodeGeneration\DotBoxD.Plugins.Analyzer\DotBoxD.Plugins.Analyzer.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\Pushdown\DotBoxD.Pushdown.Services\DotBoxD.Pushdown.Services.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- The root meta-package is the one-package authoring experience. Ship the plugin analyzer
         directly so [Plugin]/[ServerExtension] packages are generated for DotBoxD consumers. -->
    <None Include="..\..\CodeGeneration\DotBoxD.Plugins.Analyzer\bin\$(Configuration)\netstandard2.0\DotBoxD.Plugins.Analyzer.dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
    <None Include="..\..\CodeGeneration\DotBoxD.Plugins.Analyzer\bin\$(Configuration)\netstandard2.0\DotBoxD.Plugins.Analyzer.xml"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false"
          Condition="Exists('..\..\CodeGeneration\DotBoxD.Plugins.Analyzer\bin\$(Configuration)\netstandard2.0\DotBoxD.Plugins.Analyzer.xml')" />
  </ItemGroup>

</Project>
