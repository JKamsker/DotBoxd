<Project Sdk="Microsoft.NET.Sdk">

  
  <PropertyGroup>
    <Description>Preview DotBoxD MessagePack IPC addon that runs sandboxed kernels next to host RPC services, with named-pipe helpers.</Description>
    <PackageTags>dotboxd;sandbox;ipc;transport;pushdown;preview</PackageTags>
  </PropertyGroup>
<ItemGroup>
    <PackageReference Include="MessagePack" ExcludeAssets="analyzers" />
    <PackageReference Include="MessagePackAnalyzer" ExcludeAssets="all" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Kernels\DotBoxD.Kernels\DotBoxD.Kernels.csproj" />
    <ProjectReference Include="..\..\Hosting\DotBoxD.Plugins\DotBoxD.Plugins.csproj" />
    <ProjectReference Include="..\..\Services\DotBoxD.Services\DotBoxD.Services.csproj" />
    <ProjectReference Include="..\..\CodeGeneration\DotBoxD.Services.SourceGenerator\DotBoxD.Services.SourceGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\Channels\DotBoxD.Codecs.MessagePack\DotBoxD.Codecs.MessagePack.csproj" />
    <ProjectReference Include="..\..\Channels\DotBoxD.Transports.NamedPipes\DotBoxD.Transports.NamedPipes.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

</Project>
