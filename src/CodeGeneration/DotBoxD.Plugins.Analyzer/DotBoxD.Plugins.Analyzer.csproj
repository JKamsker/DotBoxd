<Project Sdk="Microsoft.NET.Sdk">

  
  <PropertyGroup>
    <Description>DotBoxD.Kernels plugin source analyzer and generator package for package-backed plugins.</Description>
    <PackageTags>dotboxd;sandbox;plugins;analyzer;source-generator</PackageTags>
  </PropertyGroup>
<ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" VersionOverride="4.14.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="$(OutputPath)\$(AssemblyName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
    <None Include="$(OutputPath)\$(AssemblyName).xml" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" Condition="Exists('$(OutputPath)\$(AssemblyName).xml')" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Shared\Defaults\*.cs" Link="Shared\Defaults\%(Filename)%(Extension)" />
    <Compile Include="..\..\Shared\HostBindings\HostBindingMetadataRules.cs" Link="Shared\HostBindingMetadataRules.cs" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <IncludeSymbols>false</IncludeSymbols>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
  </PropertyGroup>

</Project>
