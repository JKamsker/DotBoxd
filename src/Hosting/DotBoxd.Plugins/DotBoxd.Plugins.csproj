<Project Sdk="Microsoft.NET.Sdk">

  
  <PropertyGroup>
    <Description>DotBoxd.Kernels plugin manifest, installed kernel, hook, and message-binding APIs.</Description>
    <PackageTags>dotboxd;sandbox;plugins;hooks;kernels</PackageTags>
  </PropertyGroup>
<ItemGroup>
    <ProjectReference Include="..\..\Kernels\DotBoxd.Kernels\DotBoxd.Kernels.csproj" />
    <ProjectReference Include="..\DotBoxd.Hosting\DotBoxd.Hosting.csproj" />
    <ProjectReference Include="..\..\Kernels\DotBoxd.Kernels.Runtime\DotBoxd.Kernels.Runtime.csproj" />
    <ProjectReference Include="..\..\Kernels\DotBoxd.Kernels.Serialization.Json\DotBoxd.Kernels.Serialization.Json.csproj" />
    <ProjectReference Include="..\DotBoxd.Abstractions\DotBoxd.Abstractions.csproj" />
  </ItemGroup>

  <!--
    Versioned plugin-package JSON ingestion schema artifact (CMP-0012). Embedded here (rather than
    in the purpose-agnostic DotBoxd.Kernels.Serialization.Json package) and loaded via PluginPackageJsonSchemas.
    LogicalName pins the resource name regardless of build host or link path.
  -->
  <ItemGroup>
    <EmbeddedResource Include="..\..\..\schemas\v1\dotboxd-plugin-package.schema.json"
                      LogicalName="DotBoxd.Plugins.schemas.v1.dotboxd-plugin-package.schema.json"
                      Pack="true"
                      PackagePath="schemas\v1\dotboxd-plugin-package.schema.json" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

</Project>
