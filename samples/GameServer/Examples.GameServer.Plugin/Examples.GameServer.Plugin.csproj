<Project Sdk="Microsoft.NET.Sdk">

  <!-- Repo-local stand-in for the intended DotBoxD.Plugins.Sdk package: analyzer + runtime + interceptor
       namespace wiring. The packaged SDK should collapse these project references into one import. -->
  <ItemGroup>
    <ProjectReference Include="..\..\..\src\CodeGeneration\DotBoxD.Plugins.Analyzer\DotBoxD.Plugins.Analyzer.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\..\src\Hosting\DotBoxD.Plugins\DotBoxD.Plugins.csproj" />
    <ProjectReference Include="..\..\..\src\Kernels\DotBoxD.Kernels.Serialization.Json\DotBoxD.Kernels.Serialization.Json.csproj" />
    <ProjectReference Include="..\..\..\src\Pushdown\DotBoxD.Pushdown.Services\DotBoxD.Pushdown.Services.csproj" />
    <ProjectReference Include="..\Examples.GameServer.Server.Abstractions\Examples.GameServer.Server.Abstractions.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <DotBoxDGeneratedInterceptorsNamespace>DotBoxD.Plugins.Generated</DotBoxDGeneratedInterceptorsNamespace>
    <InterceptorsNamespaces>$(InterceptorsNamespaces);$(DotBoxDGeneratedInterceptorsNamespace)</InterceptorsNamespaces>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Examples.GameServer.Plugin.Tests" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Shared\PackageExporter.cs" Link="Shared\PackageExporter.cs" />
  </ItemGroup>

  <Target Name="ExportGameServerPluginPackages" AfterTargets="Build" Condition="'$(DesignTimeBuild)' != 'true'">
    <Exec Command="dotnet &quot;$(TargetPath)&quot; --export &quot;$(MSBuildProjectDirectory)\..\plugins&quot;" />
  </Target>

</Project>
