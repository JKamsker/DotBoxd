<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MessagePack" />
  </ItemGroup>

  <ItemGroup>
    <!-- Services (RPC) over a real transport + codec. -->
    <ProjectReference Include="..\..\..\src\Services\DotBoxd.Services\DotBoxd.Services.csproj" />
    <ProjectReference Include="..\..\..\src\Channels\DotBoxd.Codecs.MessagePack\DotBoxd.Codecs.MessagePack.csproj" />
    <ProjectReference Include="..\..\..\src\Channels\DotBoxd.Transports.NamedPipes\DotBoxd.Transports.NamedPipes.csproj" />

    <!-- Pushdown bridge (named-pipe RPC helpers). -->
    <ProjectReference Include="..\..\..\src\Pushdown\DotBoxd.Pushdown.Services\DotBoxd.Pushdown.Services.csproj" />

    <!-- Kernels: validate + host + run a sandboxed kernel under a policy. -->
    <ProjectReference Include="..\..\..\src\Hosting\DotBoxd.Hosting\DotBoxd.Hosting.csproj" />
    <ProjectReference Include="..\..\..\src\Kernels\DotBoxd.Kernels.Runtime\DotBoxd.Kernels.Runtime.csproj" />
    <ProjectReference Include="..\..\..\src\Kernels\DotBoxd.Kernels.Serialization.Json\DotBoxd.Kernels.Serialization.Json.csproj" />

    <!-- Source generator that turns [DotBoxdService] contracts into proxies/dispatchers. -->
    <ProjectReference Include="..\..\..\src\CodeGeneration\DotBoxd.Services.SourceGenerator\DotBoxd.Services.SourceGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

</Project>
