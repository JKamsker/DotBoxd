<Project Sdk="Microsoft.NET.Sdk">

  <!-- Ergonomics target: the whole plugin toolchain (analyzer + interceptor-namespace wiring + IL weaver)
       collapses into ONE SDK package, so a plugin author references one thing instead of four hand-wired
       project/package refs plus interceptor props. -->
  <ItemGroup>
    <PackageReference Include="DotBoxD.Plugins.Sdk" />
    <ProjectReference Include="..\Examples.GameServer.Server.Abstractions\Examples.GameServer.Server.Abstractions.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Examples.GameServer.Plugin.Tests" />
  </ItemGroup>

</Project>
